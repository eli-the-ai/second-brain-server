<%- include('partials/header') %>

<h1>Dashboard</h1>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= totalItems %></div>
    <div class="stat-label">Total Items</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= itemsToday %></div>
    <div class="stat-label">Added Today</div>
  </div>
  <div class="stat-card stat-warning">
    <div class="stat-number"><%= reviewCount %></div>
    <div class="stat-label">Needs Review</div>
  </div>
</div>

<h2>By Domain</h2>
<div class="domain-grid">
  <% domainCounts.forEach(function(d) { %>
    <a href="/items?domain=<%= d.domain %>" class="domain-card domain-<%= d.domain %>">
      <div class="domain-count"><%= d.count %></div>
      <div class="domain-name"><%= d.domain.replace('_', ' ') %></div>
    </a>
  <% }); %>
</div>

<h2>Recent Items</h2>
<table class="data-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Domain</th>
      <th>Status</th>
      <th>By</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% recentItems.forEach(function(item) { %>
      <tr>
        <td><a href="/items/<%= item.id %>"><%= item.title %></a></td>
        <td><span class="badge domain-<%= item.domain %>"><%= item.domain %></span></td>
        <td><span class="badge status-<%= item.status %>"><%= item.status %></span></td>
        <td><%= item.created_by || '—' %></td>
        <td><%= new Date(item.created_at).toLocaleDateString() %></td>
      </tr>
    <% }); %>
  </tbody>
</table>

<%- include('partials/footer') %>
