# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@vpn-host:5432/secondbrain

# Ollama API (optional — falls back to keyword classifier if unreachable)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# Slack webhook for digest delivery (optional)
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# User identity — stamps created_by on all captured items (optional)
BRAIN_USER=jsanders
