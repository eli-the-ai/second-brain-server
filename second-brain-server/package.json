{
  "name": "second-brain-server",
  "version": "1.0.0",
  "description": "MCP server providing Second Brain knowledge management tools for Claude Code",
  "type": "module",
  "bin": {
    "second-brain-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
